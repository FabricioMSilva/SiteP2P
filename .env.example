# Variáveis de Ambiente - Exemplo
# Copie este arquivo para .env.local e preencha os valores

# URL Base (opcional)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# WhatsApp (opcional)
NEXT_PUBLIC_WHATSAPP_NUMBER=24998344324

# Banco EFI - Configurações PIX
NEXT_PUBLIC_EFI_CLIENT_ID=seu_client_id_aqui
NEXT_PUBLIC_EFI_CLIENT_SECRET=seu_client_secret_aqui
NEXT_PUBLIC_EFI_CERTIFICATE_PATH=caminho_para_certificado.pem

# Analytics (opcional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Email (para formulários futuros)
NEXT_PUBLIC_CONTACT_EMAIL=contato@siteiptv.com
